# ==============================
# AI Provider API Keys
# ==============================
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ==============================
# LangSmith Configuration
# ==============================
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=college-chatbot
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ==============================
# Flask Configuration
# ==============================
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=change-this-to-a-long-random-secret-string
DEBUG=True

# ==============================
# Database
# ==============================
DATABASE_URL=sqlite:///instance/chatbot.db

# ==============================
# Vector Store
# ==============================
CHROMA_PERSIST_DIR=chroma_db
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ==============================
# Default Admin Account (created on first run)
# ==============================
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=ChangeMe123!
DEFAULT_ADMIN_EMAIL=admin@college.edu

# ==============================
# App Settings
# ==============================
COLLEGE_NAME=Springfield Institute of Technology
MAX_UPLOAD_SIZE_MB=20
